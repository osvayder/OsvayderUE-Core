{
	"FileVersion": 3,
	"Version": 11,
	"VersionName": "1.1",
	"FriendlyName": "Osvayder UE",
	"Description": "Codex-first Osvayder UE development agent for Unreal Engine 5.7 with MCP tooling, restart-survival workflows, verification receipts, and legacy Claude compatibility.",
	"Category": "Editor",
	"CreatedBy": "Osvayder",
	"CreatedByURL": "https://github.com/osvayder",
